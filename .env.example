# LLM is invoked via the `codex` CLI (npm install -g @openai/codex && codex login).
# No API key needed — codex uses your ChatGPT login.
DD_MODEL=gpt-5.5
DD_MODEL_FAST=gpt-5.5-mini
DD_CODEX_BIN=codex

# --- Web search backends ---
# Default cascade: openclaw → perplexity → gemini → tavily → duckduckgo.
# Override with DD_SEARCH_PREFERRED (comma-separated). Backends not listed
# still append as fallbacks.
# DD_SEARCH_PREFERRED=gemini,duckduckgo

# Tier 1: openclaw infer-web — uses OpenClaw's bundled providers. Zero extra
# key needed if your OpenClaw already has Gemini configured (recommended).
# Provider options: gemini | perplexity | tavily | duckduckgo | exa | firecrawl.
DD_OPENCLAW_SEARCH_PROVIDER=gemini
DD_OPENCLAW_BIN=openclaw
DD_OPENCLAW_TIMEOUT=60

# Tier 2: direct Perplexity API.
PERPLEXITY_API_KEY=pplx-...
DD_PPLX_MODEL=sonar
# Tier 3: direct Gemini with Google Search grounding.
GEMINI_API_KEY=AIza...
DD_GEMINI_MODEL=gemini-2.5-flash
# (other model options: gemini-3.5-flash, gemini-3.1-flash-lite-preview)
# Tier 4: Tavily — classic search index, URL list only.
TAVILY_API_KEY=tvly-...
# Tier 5 (no env var): DuckDuckGo HTML — last-resort, rate-limited.

# --- notice.co secondary-market scraper ---
# Pull via `python scripts/refresh_notice_cookie.py` from your logged-in browser,
# or copy-paste the cookie string from Safari Web Inspector here:
NOTICE_CO_COOKIE=

SEC_EDGAR_USER_AGENT="DD Agent contact@example.com"
DD_DATA_DIR=./data
DD_DB_PATH=./data/deals.db
DD_ENABLE_PHOTO_CLASSIFIER=1
DD_LOG_LEVEL=INFO
