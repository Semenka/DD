<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>DD Report — {{ deal_context.company_name }}</title>
<style>
  :root {
    --fg: #1a1a1a; --muted: #5a6068; --bg: #fbfbfa; --rule: #e5e5e0;
    --accent: #b14b1e; --code-bg: #f3f1ec;
  }
  html, body { background: var(--bg); color: var(--fg); }
  body {
    font-family: ui-serif, "Iowan Old Style", "Charter", Georgia, serif;
    max-width: 760px; margin: 2.5rem auto; padding: 0 1.5rem; line-height: 1.55;
    font-size: 17px;
  }
  h1 { font-size: 2rem; margin-bottom: 0.25rem; }
  h2 { font-size: 1.5rem; border-bottom: 1px solid var(--rule); padding-bottom: 0.3rem; margin-top: 2rem; }
  h3 { font-size: 1.2rem; margin-top: 1.5rem; }
  h4 { font-size: 1rem; margin-top: 1.2rem; }
  hr { border: 0; border-top: 1px solid var(--rule); margin: 2rem 0; }
  blockquote {
    margin: 1rem 0; padding: 0.6rem 1rem; border-left: 3px solid var(--accent);
    background: var(--code-bg); font-style: italic; color: var(--muted);
  }
  code {
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    background: var(--code-bg); padding: 0.05rem 0.3rem; border-radius: 3px; font-size: 0.9em;
  }
  pre code { display: block; padding: 0.8rem 1rem; overflow-x: auto; }
  table { border-collapse: collapse; width: 100%; margin: 1rem 0; font-size: 0.92em; }
  th, td { border: 1px solid var(--rule); padding: 0.45rem 0.7rem; text-align: left; vertical-align: top; }
  th { background: var(--code-bg); }
  sup.ref { color: var(--accent); font-weight: 600; }
  a { color: var(--accent); text-decoration: none; border-bottom: 1px dotted var(--accent); }
  a:hover { border-bottom-style: solid; }
  @media print {
    body { font-size: 11pt; max-width: 100%; }
    a { color: inherit; border: none; }
    h2 { page-break-after: avoid; }
    pre, table { page-break-inside: avoid; }
  }
</style>
</head>
<body>
{{ body_html | safe }}
</body>
</html>
